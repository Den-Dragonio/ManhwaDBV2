rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Чтение разрешено всем и везде
    match /{document=**} {
      allow read: if true;
    }

    // 2. Пользователи
    match /users/{userId} {
      allow create: if request.auth != null; 
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // 3. Юзернеймы (важно для регистрации)
    match /usernames/{name} {
      allow create, delete: if request.auth != null;
    }

    // 4. Рецензии
    match /reviews/{id} {
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        (request.resource.data.userId == resource.data.userId && 
         request.resource.data.titleId == resource.data.titleId)
      );
    }

    // 5. Комментарии
    match /comments/{id} {
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        (request.resource.data.userId == resource.data.userId)
      );
    }

    // 6. Друзья
    match /friends/{id} {
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.users;
    }

    // 7. Новости (уведомления о комментариях и др.)
    match /news/{id} {
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // 8. Отклонения запросов дружбы (счётчик для блокировки)
    match /rejections/{id} {
      allow create, read: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // 9. Плейлисты
    match /playlists/{id} {
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
